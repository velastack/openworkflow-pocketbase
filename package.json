{
  "name": "openworkflow-pocketbase",
  "version": "0.1.0",
  "description": "OpenWorkflow Backend backed by a velabase /api/ow/v1 HTTP API — a thin wrapper over the pocketbase-sveltekit client.",
  "keywords": [
    "openworkflow",
    "pocketbase",
    "velabase",
    "durable execution",
    "workflow"
  ],
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run test/unit.test.ts",
    "test:watch": "vitest",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "peerDependencies": {
    "openworkflow": "^0.9.0",
    "pocketbase": "^0.27.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "openworkflow": "^0.9.0",
    "pocketbase": "^0.27.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
